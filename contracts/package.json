{
  "name": "habit-contracts",
  "version": "1.0.0",
  "description": "HaBit (HBT) smart contracts for Base chain",
  "scripts": {
    "compile": "npx hardhat compile",
    "test": "npx hardhat test",
    "deploy:sepolia": "npx hardhat run scripts/deploy.js --network baseSepolia",
    "deploy:mainnet": "npx hardhat run scripts/deploy.js --network base",
    "verify:sepolia": "npx hardhat verify --network baseSepolia"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@openzeppelin/contracts": "^5.0.0",
    "hardhat": "^2.19.0",
    "dotenv": "^16.3.0"
  }
}
